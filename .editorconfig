root = true

# Most coding standards (analyzers, formatting, naming) are provided by the
# Opinionated.DotNet.CodingStandards GlobalPackageReference (see Directory.Packages.props).
# The overrides below are deliberate, narrow exceptions to those defaults.

[*.cs]

# S1312 assumes a static logger field (the Serilog/NLog/log4net convention). This codebase
# uses ASP.NET Core's constructor-injected ILogger<T>, which cannot be a static field.
dotnet_diagnostic.S1312.severity = none

# S1075 flags any hardcoded absolute URI. The one hit in this codebase is a static, well-known
# license URL (not an environment-specific endpoint), so there's nothing to extract to config.
dotnet_diagnostic.S1075.severity = none

# S4018 wants every generic method parameterizable from its arguments, but "no data" factory
# methods (ApiResponse.ErrorResponse<T>/NotFoundResponse<T>) have no T-typed argument to infer
# from, the same shape as Enumerable.Empty<T>() in the BCL.
dotnet_diagnostic.S4018.severity = none
